APP_NAME="AI Flow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Production (Laravel Cloud + Neon PostgreSQL; never file SQLite)
# DB_CONNECTION=pgsql
# DB_HOST=your-neon-direct-hostname.neon.tech
# DB_PORT=5432
# DB_DATABASE=ai_flow
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Required for workflow runs
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-5
AI_BASE_URL=https://api.openai.com/v1
AI_SITE_URL=
OPENAI_TIMEOUT=60
GITHUB_TOKEN=

# OpenRouter example (use either API key variable; do not set both)
# OPENROUTER_API_KEY=
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openrouter/free

# Comma-separated origins for browser SPA (e.g. http://localhost:8000)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Frontend (Vite): simulated workflow UI without POST /api/runs or a queue worker
# VITE_DEMO_MODE=true
