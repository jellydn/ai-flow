APP_NAME="AI Flow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Production (Laravel Cloud + Neon PostgreSQL; never file SQLite)
# DB_CONNECTION=pgsql
# DB_HOST=your-neon-direct-hostname.neon.tech
# DB_PORT=5432
# DB_DATABASE=ai_flow
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Max workflow launches per hour per IP (default 5). E2E/CI sets higher.
RUNS_RATE_LIMIT_PER_HOUR=5

# Max auth-login / auth-register attempts per minute per IP (E2E/CI sets higher).
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10
AUTH_REGISTER_RATE_LIMIT_PER_MIN=5

# Other rate limits (E2E/CI may set higher).
RUNS_STREAM_RATE_LIMIT_PER_MIN=30
MAGIC_LINK_RATE_LIMIT_PER_MIN=3
CREDENTIALS_RATE_LIMIT_PER_MIN=10

# Required for guest workflow runs
OPENROUTER_API_KEY=

# Optional provider key for signed-in runs
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-5
AI_BASE_URL=https://api.openai.com/v1
AI_SITE_URL=
OPENAI_TIMEOUT=60
GITHUB_TOKEN=

# OpenRouter-compatible endpoint example
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openrouter/free

# Comma-separated origins for browser SPA (e.g. http://localhost:8000)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Email-link (magic-link) sign-in only — not required for password sign-in (queued mail; needs worker)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@itman.fyi
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
# Post-verify redirect target for magic links (defaults to APP_URL)
FRONTEND_URL=http://localhost:8000

# Super admin bootstrap (php artisan migrate --seed): defaults to dung@productsway.com / Dung when unset
# Set empty to skip: SUPER_ADMIN_BOOTSTRAP_EMAIL=
# SUPER_ADMIN_BOOTSTRAP_EMAIL=
# SUPER_ADMIN_BOOTSTRAP_NAME="Dung"

# Dedicated encryption key for stored AI provider credentials (BYOK).
# Falls back to APP_KEY when not set. Losing this key makes all stored
# credentials unrecoverable — back it up securely.
# CREDENTIAL_ENCRYPTION_KEY=

# GitHub Bot - respond to @ai-flow commands in issue/PR comments.
# Required for webhook signature verification (set a long random string).
GITHUB_WEBHOOK_SECRET=

# GitHub App credentials (preferred; falls back to GITHUB_TOKEN if absent).
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=

# Optional: custom label for bot comments (default: ai-flow).
# GITHUB_BOT_COMMENT_LABEL=ai-flow

# Sentry error monitoring (optional; errors are only reported when DSN is set)
SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN=
# SENTRY_RELEASE=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
